---
import { getCollection } from 'astro:content';
import type { CollectionEntry } from 'astro:content';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';
import { getRelatedItems } from '../../utils/getRelatedItems';
import { getBlogPostUrl } from '../../utils/urls';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

interface Props {
  id: string;
  allProjects?: CollectionEntry<'projects'>[];
  allBlog?: CollectionEntry<'blog'>[];
}
const { id, allProjects: propProjects, allBlog: propBlog } = Astro.props;

const allProjects = propProjects ?? await getCollection('projects');
const allBlog = propBlog ?? await getCollection('blog');

const relatedItems = getRelatedItems(id, id, lang, allProjects, allBlog);

const hasRelated = relatedItems.length > 0;
const tagHref = `/${lang}/tags/${id}`;
---

<div class="tag-tooltip">
  <div class="tooltip-content">
    {hasRelated ? (
      <ul class="related-list">
        {relatedItems.map(item => (
          <li>
            <a href={item.type === 'project' ? (item.data.liveUrl || item.data.githubUrl || `/${lang}/tags/${id}`) : getBlogPostUrl(lang, item.id)}>
              <span class="item-type">{item.type === 'project' ? t('tooltip.project') : t('tooltip.article')}</span>
              <span class="item-title">{item.data.title}</span>
            </a>
          </li>
        ))}
      </ul>
    ) : (
      <p class="empty-msg">{t('tooltip.empty')}</p>
    )}
    <a href={tagHref} class="see-more">{t('tooltip.more')}</a>
  </div>
</div>

<style>
  .tag-tooltip {
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%) translateY(10px);
    width: max-content;
    max-width: 280px;
    background: var(--color-bg);
    border: var(--border-width) solid var(--color-border);
    box-shadow: 4px 4px 0px var(--color-fg);
    padding: var(--space-4);
    opacity: 0;
    visibility: hidden;
    transition: all var(--transition-fast);
    z-index: 50;
    pointer-events: none;
    text-align: left;
  }

  /* Gap bridge for hover */
  .tag-tooltip::before {
    content: '';
    position: absolute;
    top: 100%;
    left: 0;
    width: 100%;
    height: 15px;
    background: transparent;
  }

  /* Triangle pointer */
  .tag-tooltip::after {
    content: '';
    position: absolute;
    top: 100%;
    left: 50%;
    transform: translateX(-50%);
    border-width: 8px;
    border-style: solid;
    border-color: var(--color-border) transparent transparent transparent;
  }

  .related-list {
    list-style: none;
    padding: 0;
    margin: 0 0 var(--space-3) 0;
    display: flex;
    flex-direction: column;
    gap: var(--space-2);
  }

  .related-list a {
    display: flex;
    flex-direction: column;
    text-decoration: none;
    color: var(--color-fg);
    padding: var(--space-2);
    border: 1px solid transparent;
    transition: border-color var(--transition-fast);
  }

  .related-list a:hover {
    border-color: var(--color-border-soft);
  }

  .item-type {
    font-size: 0.65rem;
    font-family: var(--font-mono);
    color: var(--color-accent);
    text-transform: uppercase;
  }

  .item-title {
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    white-space: normal;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .empty-msg {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    margin: 0 0 var(--space-3) 0;
    white-space: normal;
  }

  .see-more {
    display: block;
    text-align: center;
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    color: var(--color-bg);
    background: var(--color-fg);
    padding: var(--space-2);
    text-decoration: none;
    text-transform: uppercase;
    transition: transform var(--transition-fast);
  }

  .see-more:hover {
    transform: translateY(-2px);
  }
</style>
