---
const year = new Date().getFullYear();

const socials = [
  {
    label: 'GitHub',
    href:  'https://github.com/Infuseting',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><title>GitHub</title><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>`,
  },
  {
    label: 'LinkedIn',
    href:  'https://www.linkedin.com/in/arthur-serret/',
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><title>LinkedIn</title><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>`,
  },
];
---

<footer class="footer" id="site-footer">
  <div class="footer__inner container">
    <div class="footer__brand">
      <span class="footer__name">Arthur SERRET</span>
      <span class="footer__role">Développeur Fullstack</span>
    </div>

    <nav class="footer__nav" aria-label="Navigation pied de page">
      <a href="/#projects">Projets</a>
      <a href="/#stack">Stack</a>
      <a href="/blog">Blog</a>
      <a href="/#contact">Contact</a>
    </nav>

    <div class="footer__actions">
      <ul class="footer__socials" aria-label="Réseaux sociaux" role="list">
        {socials.map(({ label, href, icon }) => (
          <li>
            <a
              href={href}
              target="_blank"
              rel="noopener noreferrer"
              aria-label={label}
              class="footer__social-link"
              set:html={icon}
            />
          </li>
        ))}
      </ul>

      <a
        href="/cv.pdf"
        download="CV_Arthur_SERRET.pdf"
        class="footer__cv"
      >
        Télécharger CV ↓
      </a>
    </div>
  </div>

  <div class="footer__bottom container">
    <p>© {year} Arthur SERRET. Tous droits réservés.</p>
    <p class="footer__built">Construit avec <a href="https://astro.build" target="_blank" rel="noopener noreferrer">Astro</a></p>
  </div>
</footer>

<style>
  .footer {
    border-top: var(--border-width) solid var(--color-border);
    background: var(--color-bg-alt);
    margin-top: var(--space-24);
  }

  .footer__inner {
    display: grid;
    grid-template-columns: 1fr auto auto;
    align-items: center;
    gap: var(--space-8);
    padding-block: var(--space-12);
  }

  @media (max-width: 768px) {
    .footer__inner {
      grid-template-columns: 1fr;
      gap: var(--space-6);
    }
  }

  .footer__brand {
    display: flex;
    flex-direction: column;
    gap: var(--space-1);
  }

  .footer__name {
    font-family: var(--font-display);
    font-size: var(--text-xl);
    font-weight: var(--weight-black);
    color: var(--color-fg);
    letter-spacing: var(--tracking-tight);
  }

  .footer__role {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
  }

  .footer__nav {
    display: flex;
    gap: var(--space-6);
    flex-wrap: wrap;
  }

  .footer__nav a {
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-fg-muted);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer__nav a:hover { color: var(--color-accent); }

  .footer__actions {
    display: flex;
    align-items: center;
    gap: var(--space-4);
  }

  .footer__socials {
    display: flex;
    gap: var(--space-2);
    list-style: none;
  }

  .footer__social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    color: var(--color-fg-muted);
    border: var(--border-width) solid var(--color-border-soft);
    transition:
      color var(--transition-fast),
      background-color var(--transition-fast),
      transform var(--transition-brutal),
      box-shadow var(--transition-brutal);
  }

  .footer__social-link:hover {
    color: var(--color-bg);
    background: var(--color-fg);
    transform: translate(-2px, -2px);
    box-shadow: var(--shadow-brutal);
  }

  .footer__cv {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-bg);
    background: var(--color-accent);
    border: var(--border-width) solid var(--color-accent);
    padding: var(--space-2) var(--space-4);
    text-decoration: none;
    transition:
      transform var(--transition-brutal),
      box-shadow var(--transition-brutal),
      background-color var(--transition-fast);
  }

  .footer__cv:hover {
    background: var(--color-accent-dark);
    border-color: var(--color-accent-dark);
    transform: translate(-2px, -2px);
    box-shadow: 4px 4px 0 var(--color-accent-dark);
  }

  .footer__bottom {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding-block: var(--space-4);
    border-top: 1px solid var(--color-border-soft);
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .footer__bottom p {
    font-size: var(--text-xs);
    color: var(--color-fg-subtle);
    max-width: none;
    margin: 0;
    line-height: 1;
  }

  .footer__built a {
    color: var(--color-fg-subtle);
    text-decoration: underline;
    text-underline-offset: 3px;
  }

  .footer__built a:hover { color: var(--color-accent); }
</style>
