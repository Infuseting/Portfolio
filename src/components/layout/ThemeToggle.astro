---
// ThemeToggle — reads/writes data-theme + localStorage
---
<button
  id="theme-toggle"
  class="theme-toggle"
  aria-label="Basculer le thème"
  title="Basculer le thème"
>
  <!-- Sun icon (shown in dark mode) -->
  <svg class="icon icon--sun" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <circle cx="12" cy="12" r="5"/>
    <line x1="12" y1="1" x2="12" y2="3"/>
    <line x1="12" y1="21" x2="12" y2="23"/>
    <line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/>
    <line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/>
    <line x1="1" y1="12" x2="3" y2="12"/>
    <line x1="21" y1="12" x2="23" y2="12"/>
    <line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/>
    <line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/>
  </svg>
  <!-- Moon icon (shown in light mode) -->
  <svg class="icon icon--moon" xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
  </svg>
</button>

<script>
  function initThemeToggle(): void {
    const btn = document.getElementById('theme-toggle');
    if (!btn) return;

    const html = document.documentElement;

    function getTheme(): string {
      return html.getAttribute('data-theme') ?? 'light';
    }

    function setTheme(theme: string): void {
      html.setAttribute('data-theme', theme);
      localStorage.setItem('theme', theme);
    }

    btn.addEventListener('click', () => {
      setTheme(getTheme() === 'dark' ? 'light' : 'dark');
    });
  }

  // Init on load and after each View Transition
  initThemeToggle();
  document.addEventListener('astro:page-load', initThemeToggle);
</script>

<style>
  .theme-toggle {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    background: transparent;
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-none);
    cursor: pointer;
    color: var(--color-fg);
    transition:
      background-color var(--transition-fast),
      color var(--transition-fast),
      transform var(--transition-brutal),
      box-shadow var(--transition-brutal);
  }

  .theme-toggle:hover {
    background: var(--color-fg);
    color: var(--color-bg);
    transform: translate(-2px, -2px);
    box-shadow: var(--shadow-brutal);
  }

  .theme-toggle:active {
    transform: translate(1px, 1px);
    box-shadow: 1px 1px 0 var(--color-border);
  }

  /* Icon visibility controlled by data-theme */
  :root[data-theme="light"] .icon--sun,
  :root:not([data-theme="dark"]) .icon--sun { display: none; }

  :root[data-theme="dark"]  .icon--moon { display: none; }

  @media (prefers-color-scheme: dark) {
    :root:not([data-theme="light"]) .icon--sun  { display: block; }
    :root:not([data-theme="light"]) .icon--moon { display: none; }
  }
</style>
