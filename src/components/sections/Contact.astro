---
import SectionLabel from '../ui/SectionLabel.astro';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);
---

<section class="contact section" id="contact" aria-label="Contact">
  <div class="container">
    <div class="contact__inner">
      <SectionLabel label={t('contact.badge')} />

      <h2 class="contact__title">
        {t('contact.title')}
      </h2>

      <p class="contact__description">
        {t('contact.description')}
      </p>

      <div class="contact__actions">
        <a
          href="mailto:serretarthur@gmail.com"
          class="contact__email-btn"
          id="contact-email-btn"
          aria-label="Envoyer un email à Arthur SERRET"
        >
          <span class="contact__email-text">serretarthur@gmail.com</span>
          <span class="contact__email-arrow" aria-hidden="true">→</span>
        </a>
      </div>

      <div class="contact__socials" aria-label="Réseaux professionnels">
        <a
          href="https://www.linkedin.com/in/arthur-serret/"
          target="_blank"
          rel="noopener noreferrer"
          class="contact__social"
          aria-label="Profil LinkedIn d'Arthur SERRET"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><title>LinkedIn</title><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
          LinkedIn
        </a>

        <a
          href="https://github.com/Infuseting"
          target="_blank"
          rel="noopener noreferrer"
          class="contact__social"
          aria-label="Profil GitHub d'Arthur SERRET"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><title>GitHub</title><path d="M12 .297c-6.63 0-12 5.373-12 12 0 5.303 3.438 9.8 8.205 11.385.6.113.82-.258.82-.577 0-.285-.01-1.04-.015-2.04-3.338.724-4.042-1.61-4.042-1.61C4.422 18.07 3.633 17.7 3.633 17.7c-1.087-.744.084-.729.084-.729 1.205.084 1.838 1.236 1.838 1.236 1.07 1.835 2.809 1.305 3.495.998.108-.776.417-1.305.76-1.605-2.665-.3-5.466-1.332-5.466-5.93 0-1.31.465-2.38 1.235-3.22-.135-.303-.54-1.523.105-3.176 0 0 1.005-.322 3.3 1.23.96-.267 1.98-.399 3-.405 1.02.006 2.04.138 3 .405 2.28-1.552 3.285-1.23 3.285-1.23.645 1.653.24 2.873.12 3.176.765.84 1.23 1.91 1.23 3.22 0 4.61-2.805 5.625-5.475 5.92.42.36.81 1.096.81 2.22 0 1.606-.015 2.896-.015 3.286 0 .315.21.69.825.57C20.565 22.092 24 17.592 24 12.297c0-6.627-5.373-12-12-12"/></svg>
          GitHub
        </a>

        <a
          href="/cv.pdf"
          download="CV_Arthur_SERRET.pdf"
          class="contact__social"
          aria-label="Télécharger le CV d'Arthur SERRET"
        >
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><title>CV</title><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
          {t('hero.cv')}
        </a>
      </div>
    </div>

    <!-- Decorative large text -->
    <div class="contact__deco" aria-hidden="true">HELLO</div>
  </div>
</section>

<style>
  .contact {
    position: relative;
    overflow: hidden;
    border-top: var(--border-width) solid var(--color-border-soft);
  }

  .contact .container {
    position: relative;
  }

  .contact__inner {
    display: flex;
    flex-direction: column;
    gap: var(--space-8);
    max-width: 640px;
    position: relative;
    z-index: 1;
  }

  .contact__title {
    font-size: clamp(var(--text-4xl), 6vw, var(--text-7xl));
    line-height: var(--leading-tight);
  }

  .contact__title-accent {
    color: var(--color-accent);
    -webkit-text-stroke: 2px var(--color-accent);
    color: transparent;
  }

  [data-theme="dark"] .contact__title-accent {
    -webkit-text-stroke: 2px var(--color-accent);
  }

  .contact__description {
    font-size: var(--text-lg);
    color: var(--color-fg-muted);
    max-width: 45ch;
    margin: 0;
  }

  /* Email button */
  .contact__email-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--space-4);
    border: var(--border-width-thick) solid var(--color-border);
    padding: var(--space-5) var(--space-8);
    text-decoration: none;
    transition:
      transform var(--transition-brutal),
      box-shadow var(--transition-brutal),
      background-color var(--transition-fast),
      color var(--transition-fast);
    background: transparent;
    max-width: fit-content;
  }

  .contact__email-btn:hover {
    background: var(--color-fg);
    color: var(--color-bg);
    transform: translate(-4px, -4px);
    box-shadow: var(--shadow-brutal-lg);
  }

  .contact__email-text {
    font-family: var(--font-mono);
    font-size: clamp(var(--text-sm), 2vw, var(--text-lg));
    color: var(--color-fg);
    transition: color var(--transition-fast);
  }

  .contact__email-btn:hover .contact__email-text {
    color: var(--color-bg);
  }

  .contact__email-arrow {
    font-size: var(--text-2xl);
    font-weight: var(--weight-bold);
    color: var(--color-accent);
    transition:
      transform var(--transition-brutal),
      color var(--transition-fast);
  }

  .contact__email-btn:hover .contact__email-arrow {
    transform: translateX(6px);
    color: var(--color-bg);
  }

  /* Social links */
  .contact__socials {
    display: flex;
    gap: var(--space-4);
    flex-wrap: wrap;
  }

  .contact__social {
    display: inline-flex;
    align-items: center;
    gap: var(--space-2);
    font-family: var(--font-display);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-fg-muted);
    text-decoration: none;
    border: var(--border-width) solid var(--color-border-soft);
    padding: var(--space-2) var(--space-4);
    transition:
      color var(--transition-fast),
      background-color var(--transition-fast),
      border-color var(--transition-fast),
      transform var(--transition-brutal);
  }

  .contact__social:hover {
    color: var(--color-bg);
    background: var(--color-fg);
    border-color: var(--color-fg);
    transform: translate(-2px, -2px);
  }

  /* Decorative background text */
  .contact__deco {
    position: absolute;
    right: -2rem;
    top: 50%;
    transform: translateY(-50%);
    font-family: var(--font-display);
    font-weight: var(--weight-black);
    font-size: clamp(8rem, 18vw, 20rem);
    line-height: 1;
    color: var(--color-border-soft);
    opacity: 0.2;
    pointer-events: none;
    user-select: none;
    letter-spacing: var(--tracking-tight);
  }

  @media (max-width: 768px) {
    .contact__deco { display: none; }
    .contact__email-btn { padding: var(--space-4) var(--space-6); }
  }
</style>
