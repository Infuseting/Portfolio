---
import { getCollection } from 'astro:content';
import SectionLabel from '../ui/SectionLabel.astro';
import Tag from '../ui/Tag.astro';
import Button from '../ui/Button.astro';
import { formatDate } from '../../utils/formatDate';
import { getLangFromUrl, useTranslations } from '../../i18n/utils';

import { getBlogPostUrl } from '../../utils/urls';

const lang = getLangFromUrl(Astro.url);
const t = useTranslations(lang);

const [allPosts, allTags, allProjects] = await Promise.all([
  getCollection('blog'),
  getCollection('tags'),
  getCollection('projects')
]);
const posts = allPosts
  .filter((p) => !p.data.draft && p.id.startsWith(`${lang}/`))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3);
---

<section class="blog-preview section" id="blog" aria-label="Blog">
  <div class="container">
    <header class="blog-preview__header">
      <SectionLabel label={t('nav.blog')} />
      <div class="blog-preview__heading-row">
        <h2 class="blog-preview__title">{t('blogpreview.title')}</h2>
        <Button href={`/${lang}/blog`} variant="ghost" size="sm">
          {t('blogpreview.all')}
        </Button>
      </div>
    </header>

    {posts.length === 0 ? (
      <p class="blog-preview__empty">{t('blogpreview.empty')}</p>
    ) : (
      <ul class="blog-preview__list" role="list">
        {posts.map((post, i) => (
          <li class:list={['blog-card', { 'blog-card--featured': i === 0 }]}>
            <article>
              <div class="blog-card__content">
                <div class="blog-card__meta">
                  <time datetime={post.data.publishDate.toISOString()} class="blog-card__date">
                    {formatDate(post.data.publishDate, lang)}
                  </time>
                  <ul class="blog-card__tags">
                    {post.data.tags.slice(0, 2).map((tag: string) => (
                      <li><Tag label={tag} allTags={allTags} allProjects={allProjects} allBlog={allPosts} /></li>
                    ))}
                  </ul>
                </div>

                <h3 class="blog-card__title">
                  <a href={getBlogPostUrl(lang, post.id)} class="blog-card__title-link" aria-label={post.data.title}>
                    {post.data.title}
                  </a>
                </h3>
                <p class="blog-card__desc">{post.data.description}</p>

                <span class="blog-card__read">{t('blogpreview.read')}</span>
              </div>
            </article>
          </li>
        ))}
      </ul>
    )}
  </div>
</section>

<style>
  .blog-preview__header {
    margin-bottom: var(--space-10);
  }

  .blog-preview__heading-row {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: var(--space-4);
    margin-top: var(--space-3);
    flex-wrap: wrap;
  }

  .blog-preview__title {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
  }

  .blog-preview__empty {
    color: var(--color-fg-muted);
    font-style: italic;
  }

  /* List */
  .blog-preview__list {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 0;
    list-style: none;
    border: var(--border-width) solid var(--color-border);
  }

  .blog-card {
    border-right: var(--border-width) solid var(--color-border);
    transition:
      background-color var(--transition-fast),
      transform var(--transition-brutal),
      box-shadow var(--transition-brutal);
    position: relative;
  }

  .blog-card:last-child { border-right: none; }

  .blog-card:hover {
    transform: translate(-3px, -3px);
    box-shadow: var(--shadow-brutal-hover);
    z-index: 1;
    background: var(--color-bg-alt);
  }

  /* Featured card (first) */
  @media (min-width: 900px) {
    .blog-preview__list {
      grid-template-columns: 1.5fr 1fr 1fr;
    }
  }

  .blog-card__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-8);
    height: 100%;
  }

  .blog-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    position: relative;
    z-index: 2; /* Tags clickable */
  }

  .blog-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
  }

  .blog-card__date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-fg-subtle);
  }

  .blog-card__title {
    font-size: var(--text-xl);
    font-weight: var(--weight-black);
    line-height: var(--leading-snug);
    word-wrap: break-word;
    overflow-wrap: break-word;
    hyphens: auto;
  }

  .blog-card__title-link {
    color: var(--color-fg);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  /* Make whole card clickable via pseudo-element */
  .blog-card__title-link::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
  }

  .blog-card:hover .blog-card__title-link {
    color: var(--color-accent);
  }

  .blog-card__desc {
    font-size: var(--text-sm);
    color: var(--color-fg-muted);
    line-height: var(--leading-normal);
    max-width: none;
    flex: 1;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .blog-card__read {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-accent);
    margin-top: auto;
    transition: letter-spacing var(--transition-brutal);
  }

  .blog-card:hover .blog-card__read {
    letter-spacing: var(--tracking-wider, 0.1em);
  }

  @media (max-width: 768px) {
    .blog-preview__list {
      grid-template-columns: 1fr;
    }

    .blog-card {
      border-right: none;
      border-bottom: var(--border-width) solid var(--color-border);
    }

    .blog-card:last-child { border-bottom: none; }
  }
</style>
