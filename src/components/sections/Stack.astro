---
import SectionLabel from '../ui/SectionLabel.astro';
import { Icon } from 'astro-icon/components';

interface TechItem {
  name: string;
  icon: string; // astro-icon name
  color?: string;
}

interface Category {
  label: string;
  items: TechItem[];
}

const stack: Category[] = [
  {
    label: 'Langages',
    items: [
      { name: 'Java',       icon: 'mdi:language-java',  color: '#007396' },
      { name: 'Python',     icon: 'simple-icons:python', color: '#3776AB' },
      { name: 'Rust',       icon: 'simple-icons:rust',  color: '#DEA584' },
      { name: 'C',          icon: 'simple-icons:c',  color: '#A8B9CC' },
      { name: 'Kotlin',     icon: 'simple-icons:kotlin',  color: '#7F52FF' },
      { name: 'PHP',        icon: 'simple-icons:php',  color: '#777bb4' },
    ],
  },
  {
    label: 'Web & App',
    items: [
      { name: 'TypeScript', icon: 'simple-icons:typescript', color: '#3178c6' },
      { name: 'JavaScript', icon: 'simple-icons:javascript', color: '#f7df1e' },
      { name: 'React',      icon: 'simple-icons:react', color: '#61DAFB' },
      { name: 'Node.js',    icon: 'simple-icons:nodedotjs',  color: '#339933' },
      { name: 'Electron',   icon: 'simple-icons:electron', color: '#47848F' },
      { name: 'Dart',       icon: 'simple-icons:dart',  color: '#0175C2' },
    ],
  },
  {
    label: 'Data & DevOps',
    items: [
      { name: 'SQL / DB',   icon: 'simple-icons:postgresql', color: '#336791' },
      { name: 'Docker',     icon: 'simple-icons:docker', color: '#2496ed' },
      { name: 'GitHub CI',  icon: 'simple-icons:githubactions',  color: '#8b949e' },
      { name: 'GitLab CI',  icon: 'simple-icons:gitlab', color: '#FC6D26' },
    ],
  },
];
---

<section class="stack section" id="stack" aria-label="Stack technique">
  <div class="container">
    <header class="stack__header">
      <SectionLabel label="Technologies" />
      <h2 class="stack__title">Mon stack</h2>
    </header>

    <div class="stack__categories">
      {stack.map((category) => (
        <div class="stack__category">
          <h3 class="stack__category-label">{category.label}</h3>
          <ul class="stack__items" role="list">
            {category.items.map((tech) => (
              <li class="stack__item" style={`--tech-color: ${tech.color ?? 'var(--color-accent)'}`}>
                <span class="stack__item-icon" aria-hidden="true"><Icon name={tech.icon} width={20} height={20} /></span>
                <span class="stack__item-name">{tech.name}</span>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .stack__header {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    margin-bottom: var(--space-12);
  }

  .stack__title {
    font-size: clamp(var(--text-3xl), 4vw, var(--text-5xl));
  }

  .stack__categories {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 0;
    border: var(--border-width) solid var(--color-border);
  }

  .stack__category {
    padding: var(--space-8);
    border-right: var(--border-width) solid var(--color-border);
  }

  .stack__category:last-child {
    border-right: none;
  }

  .stack__category-label {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-widest);
    text-transform: uppercase;
    color: var(--color-accent);
    margin-bottom: var(--space-6);
    padding-bottom: var(--space-3);
    border-bottom: var(--border-width) solid var(--color-border-soft);
  }

  .stack__items {
    display: flex;
    flex-direction: column;
    gap: var(--space-4);
    list-style: none;
  }

  .stack__item {
    display: flex;
    align-items: center;
    gap: var(--space-4);
    padding: var(--space-3) var(--space-4);
    border: var(--border-width) solid var(--color-border);
    background: var(--color-bg);
    transition: transform var(--transition-brutal), box-shadow var(--transition-brutal);
    cursor: default;
  }

  .stack__item:hover {
    transform: translate(-4px, -4px);
    box-shadow: 4px 4px 0px var(--tech-color, var(--color-fg));
    border-color: var(--tech-color, var(--color-border));
  }

  .stack__item-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 2.5rem;
    height: 2.5rem;
    flex-shrink: 0;
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    font-weight: var(--weight-bold);
    background: var(--color-bg-alt);
    color: var(--color-fg);
    border: var(--border-width) solid var(--color-border);
    border-radius: var(--radius-none);
    transition: all var(--transition-fast);
  }

  .stack__item:hover .stack__item-icon {
    background: var(--tech-color, var(--color-accent));
    color: var(--color-bg);
    border-color: var(--tech-color, var(--color-accent));
  }

  .stack__item-name {
    font-family: var(--font-body);
    font-size: var(--text-base);
    font-weight: var(--weight-bold);
    color: var(--color-fg);
  }

  @media (max-width: 900px) {
    .stack__categories {
      grid-template-columns: 1fr;
    }

    .stack__category {
      border-right: none;
      border-bottom: var(--border-width) solid var(--color-border);
    }

    .stack__category:last-child { border-bottom: none; }

    .stack__items {
      display: grid;
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .stack__items {
      grid-template-columns: 1fr;
    }
  }
</style>
