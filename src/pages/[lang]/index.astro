---
export function getStaticPaths() {
  return [
    { params: { lang: 'fr' } },
    { params: { lang: 'en' } },
  ];
}

import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Hero from '../../components/sections/Hero.astro';
import Projects from '../../components/sections/Projects.astro';
import Stack from '../../components/sections/Stack.astro';
import BlogPreview from '../../components/sections/BlogPreview.astro';
import Contact from '../../components/sections/Contact.astro';
const { lang } = Astro.params;
---

<BaseLayout
  title="Arthur SERRET"
  description={lang === 'en' ? 'Arthur SERRET — Full-Stack Developer (Java, Angular, TypeScript) based in France.' : 'Arthur SERRET — Développeur Full-Stack (Java, Angular, TypeScript) basé en France.'}
>
  <Header />
  <main id="main-content" style="padding-top: var(--header-h);">
    <Hero />
    <Projects />
    <Stack />
    <BlogPreview />
    <Contact />
  </main>
  <Footer />
</BaseLayout>
