---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/BaseLayout.astro';
import Header from '../../components/layout/Header.astro';
import Footer from '../../components/layout/Footer.astro';
import Tag from '../../components/ui/Tag.astro';
import SectionLabel from '../../components/ui/SectionLabel.astro';

export async function getStaticPaths() {
  const allTags = await getCollection('tags');
  const allProjects = await getCollection('projects');
  const allBlog = await getCollection('blog');

  const uniqueTagNames = new Set<string>();
  
  allProjects.forEach(p => p.data.tags?.forEach((t: string) => uniqueTagNames.add(t)));
  allBlog.forEach(b => b.data.tags?.forEach((t: string) => uniqueTagNames.add(t)));

  const paths = [];
  const handledNames = new Set<string>();

  for (const tag of allTags) {
    handledNames.add(tag.id.toLowerCase());
    handledNames.add(tag.data.name.toLowerCase());
    paths.push({
      params: { slug: tag.id },
      props: { tag }
    });
  }

  for (const tagName of uniqueTagNames) {
    if (!handledNames.has(tagName.toLowerCase())) {
      const slug = tagName.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
      paths.push({
        params: { slug },
        props: { 
          tag: { id: slug, data: { name: tagName } }
        }
      });
      handledNames.add(tagName.toLowerCase());
    }
  }

  return paths;
}

const { tag } = Astro.props;

const [allProjects, allBlog] = await Promise.all([
  getCollection('projects'),
  getCollection('blog'),
]);

const matchTag = (tagArr: string[]) => tagArr.some((t: string) => 
  t.toLowerCase() === tag.id.toLowerCase() || 
  t.toLowerCase() === tag.data.name.toLowerCase()
);

const projects = allProjects.filter((p: any) => matchTag(p.data.tags || [])).sort((a: any, b: any) => a.data.order - b.data.order);
const blogPosts = allBlog.filter((b: any) => matchTag(b.data.tags || [])).sort((a: any, b: any) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<Layout title={`Tag: ${tag.data.name} | Mon Portfolio`} description={`Tous mes projets et articles liés à ${tag.data.name}`}>
  <Header />
  <main class="tag-page section container" id="main-content" style="padding-top: var(--header-h);">
    <header class="tag-header">
      <SectionLabel label="Recherche par technologie" />
      <h1 class="title" style={`--tag-color: ${tag.data.color || 'var(--color-accent)'}`}>
        {tag.data.name}
      </h1>
      <p class="subtitle">Tous les projets et articles utilisant cette technologie.</p>
    </header>

    {projects.length > 0 && (
      <section class="tag-section">
        <h2 class="section-title">Projets</h2>
        <ul class="projects__grid" role="list">
          {projects.map((project: any) => (
            <li class="project-card">
              <article>
                <div class="project-card__header">
                  <span class="project-card__year">{project.data.year}</span>
                  <div class="project-card__links">
                    {project.data.liveUrl && (
                      <a href={project.data.liveUrl} target="_blank" rel="noopener noreferrer" class="project-card__link">↗</a>
                    )}
                  </div>
                </div>
                <h3 class="project-card__title">{project.data.title}</h3>
                <p class="project-card__desc">{project.data.description}</p>
                <ul class="project-card__tags">
                  {project.data.tags.map((t: string) => (
                    <li><Tag label={t} /></li>
                  ))}
                </ul>
              </article>
            </li>
          ))}
        </ul>
      </section>
    )}

    {blogPosts.length > 0 && (
      <section class="tag-section">
        <h2 class="section-title">Articles</h2>
        <ul class="blog-grid" role="list">
          {blogPosts.map((post: any) => (
            <li class="blog-card">
              <article>
                <div class="blog-card__content">
                  <div class="blog-card__meta">
                    <time datetime={post.data.publishDate.toISOString()} class="blog-card__date">
                      {post.data.publishDate.toLocaleDateString('fr-FR', { year: 'numeric', month: 'short', day: 'numeric' })}
                    </time>
                    <ul class="blog-card__tags">
                      {post.data.tags.slice(0, 2).map((t: string) => (
                        <li><Tag label={t} /></li>
                      ))}
                    </ul>
                  </div>
                  <h3 class="blog-card__title">
                    <a href={`/blog/${post.slug}`} class="blog-card__title-link" aria-label={post.data.title}>
                      {post.data.title}
                    </a>
                  </h3>
                  <p class="blog-card__desc">{post.data.description}</p>
                  <span class="blog-card__read">Lire l'article →</span>
                </div>
              </article>
            </li>
          ))}
        </ul>
      </section>
    )}

    {projects.length === 0 && blogPosts.length === 0 && (
      <p class="empty-state">Aucun projet ni article pour cette technologie pour le moment.</p>
    )}
    
    <div class="back-link">
      <a href="/">&larr; Retour à l'accueil</a>
    </div>
  </main>
  <Footer />
</Layout>

<style>
  .tag-page {
    padding-top: var(--space-24);
    padding-bottom: var(--space-24);
  }
  .tag-header {
    margin-bottom: var(--space-12);
  }
  .title {
    font-size: clamp(var(--text-4xl), 5vw, var(--text-6xl));
    color: var(--tag-color);
  }
  .subtitle {
    font-size: var(--text-lg);
    color: var(--color-fg-muted);
    margin-top: var(--space-4);
  }

  .tag-section {
    margin-bottom: var(--space-12);
  }
  .section-title {
    font-size: var(--text-2xl);
    margin-bottom: var(--space-6);
    border-bottom: var(--border-width) solid var(--color-border-soft);
    padding-bottom: var(--space-2);
  }

  /* Projects Grid */
  .projects__grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-6);
    list-style: none;
  }
  .project-card {
    border: var(--border-width) solid var(--color-border);
    transition: transform var(--transition-brutal), box-shadow var(--transition-brutal);
    padding: var(--space-6);
    background: var(--color-bg);
  }
  .project-card:hover {
    transform: translate(-3px, -3px);
    box-shadow: var(--shadow-brutal-hover);
  }
  .project-card__header {
    display: flex;
    justify-content: space-between;
    margin-bottom: var(--space-4);
  }
  .project-card__year {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-fg-subtle);
  }
  .project-card__title {
    font-size: var(--text-xl);
    margin-bottom: var(--space-2);
  }
  .project-card__desc {
    color: var(--color-fg-muted);
    font-size: var(--text-sm);
    margin-bottom: var(--space-4);
  }
  .project-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
  }
  .project-card__link {
    border: var(--border-width) solid var(--color-border);
    padding: 2px 8px;
    text-decoration: none;
    color: var(--color-fg);
  }
  .project-card__link:hover {
    background: var(--color-fg);
    color: var(--color-bg);
  }

  /* Blog Grid */
  .blog-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
    gap: var(--space-6);
    list-style: none;
  }
  .blog-card {
    border: var(--border-width) solid var(--color-border);
    transition: transform var(--transition-brutal), box-shadow var(--transition-brutal);
    background: var(--color-bg);
    position: relative;
    height: 100%;
  }
  .blog-card:hover {
    transform: translate(-3px, -3px);
    box-shadow: var(--shadow-brutal-hover);
    background: var(--color-bg-alt);
    z-index: 1;
  }
  .blog-card__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-3);
    padding: var(--space-6);
    height: 100%;
  }
  .blog-card__meta {
    display: flex;
    align-items: center;
    gap: var(--space-2);
    flex-wrap: wrap;
    position: relative;
    z-index: 2; /* Tags clickable */
  }
  .blog-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
  }
  .blog-card__date {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    color: var(--color-fg-muted);
  }
  .blog-card__title {
    font-size: var(--text-xl);
    font-weight: var(--weight-black);
    line-height: var(--leading-snug);
    margin-bottom: var(--space-2);
    word-wrap: break-word;
    overflow-wrap: break-word;
    hyphens: auto;
  }
  .blog-card__title-link {
    color: var(--color-fg);
    text-decoration: none;
    transition: color var(--transition-fast);
  }
  .blog-card__title-link::after {
    content: '';
    position: absolute;
    inset: 0;
    z-index: 1;
  }
  .blog-card:hover .blog-card__title-link {
    color: var(--color-accent);
  }
  .blog-card__desc {
    color: var(--color-fg-muted);
    font-size: var(--text-sm);
    margin-bottom: var(--space-4);
    line-height: var(--leading-normal);
    flex: 1;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
  .blog-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-2);
    list-style: none;
    margin-bottom: var(--space-4);
  }
  .blog-card__read {
    font-family: var(--font-display);
    font-size: var(--text-xs);
    font-weight: var(--weight-bold);
    letter-spacing: var(--tracking-wide);
    text-transform: uppercase;
    color: var(--color-accent);
    margin-top: auto;
    transition: letter-spacing var(--transition-brutal);
  }
  .blog-card:hover .blog-card__read {
    letter-spacing: var(--tracking-wider, 0.1em);
  }

  .empty-state {
    font-style: italic;
    color: var(--color-fg-muted);
    margin-bottom: var(--space-8);
  }

  .back-link {
    margin-top: var(--space-12);
  }
  .back-link a {
    color: var(--color-fg);
    font-family: var(--font-mono);
    font-size: var(--text-sm);
    text-transform: uppercase;
    text-decoration: none;
  }
  .back-link a:hover {
    text-decoration: underline;
  }
</style>
